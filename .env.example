# Clash external-controller API (Mihomo / OpenClash / Nikki default port 9090)
# Configure in Settings -> Clash backend, or uncomment for build-time default:
# VITE_MIHOMO_HOST=http://127.0.0.1:9090

# external-controller secret
# VITE_MIHOMO_SECRET=your-secret

# Mihomo Storage cache key (read/write via /mihomo/storage/{key})
# VITE_MIHOMO_CONFIG_STORAGE_KEY=oneboard:config-yaml

# Mihomo config file path on gateway (optional, for "Reload from Mihomo")
# VITE_MIHOMO_CONFIG_PATH=/etc/mihomo/config.yaml

# Production static deploy: set true when Nginx proxies /mihomo
# VITE_MIHOMO_USE_PROXY=true

# VoHive API origin (no /api suffix)
# Wrong: http://127.0.0.1:7575/api  -> becomes /api/api/...
# VITE_VOHIVE_HOST=http://127.0.0.1:7575

# VoHive read-only API token (optional)
# VITE_VOHIVE_TOKEN=your-bearer-token

# Production static deploy: Nginx proxies /vohive/ prefix only
# VITE_VOHIVE_USE_PROXY=true

# Disable SSE if gateway has no push endpoint
# VITE_VOHIVE_SSE=false

# Docker production (device: docker compose pull && docker compose up -d)
# ONEBOARD_IMAGE=ghcr.io/oneboard/oneboard:1.1
# ONEBOARD_PORT=8866

# Host-Aware Control Plane — Docker
# ONEBORD_PORT=8866
# ONEBORD_RUNTIME=docker

# oneboard-agent targets (runtime env, not baked into frontend)
# ONEBORD_MIHOMO_UPSTREAM=http://127.0.0.1:9090
# ONEBORD_MIHOMO_SECRET=your-secret
# ONEBORD_VOHIVE_UPSTREAM=http://127.0.0.1:7575
# ONEBORD_VOHIVE_TOKEN=your-bearer-token

# Docker host metrics — mount host /proc and root in compose:
#   -v /proc:/host/proc:ro
#   -v /:/host/root:ro
# ONEBORD_PROC_ROOT=/host/proc
# ONEBORD_DISK_PATH=/host/root
