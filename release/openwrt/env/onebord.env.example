ONEBORD_RUNTIME=openwrt
ONEBORD_APP_ROOT=/opt/onebord
ONEBORD_DIST_DIR=/opt/onebord/dist
ONEBORD_HOST=0.0.0.0
ONEBORD_PORT=18080

# Local OpenClash/Mihomo external-controller (optional):
# ONEBORD_MIHOMO_UPSTREAM=http://127.0.0.1:9090
# ONEBORD_MIHOMO_SECRET=your-secret

# VoHive upstream (optional):
# ONEBORD_VOHIVE_UPSTREAM=http://127.0.0.1:7575
# ONEBORD_VOHIVE_TOKEN=your-token

# OpenWrt native host collection
ONEBORD_PROC_ROOT=/proc
ONEBORD_DISK_PATH=/
