#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

ONEBORD_HOME="${ONEBORD_HOME:-/opt/onebord}"
ONEBORD_ENV="${ONEBORD_ENV:-/etc/onebord/onebord.env}"
ONEBORD_BIN="${ONEBORD_BIN:-/usr/bin/onebord}"

start_service() {
  [ -f "$ONEBORD_ENV" ] && . "$ONEBORD_ENV"

  CMD="$ONEBORD_BIN"
  if [ ! -x "$CMD" ]; then
    CMD="$ONEBORD_HOME/bin/onebord-agent"
  fi

  procd_open_instance
  procd_set_param command "$CMD"
  procd_set_param env \
    ONEBORD_APP_ROOT="${ONEBORD_APP_ROOT:-$ONEBORD_HOME}" \
    ONEBORD_DIST_DIR="${ONEBORD_DIST_DIR:-$ONEBORD_HOME/dist}" \
    ONEBORD_RUNTIME="${ONEBORD_RUNTIME:-openwrt}" \
    ONEBORD_HOST="${ONEBORD_HOST:-0.0.0.0}" \
    ONEBORD_PORT="${ONEBORD_PORT:-18080}" \
    ONEBORD_MIHOMO_UPSTREAM="${ONEBORD_MIHOMO_UPSTREAM:-}" \
    ONEBORD_VOHIVE_UPSTREAM="${ONEBORD_VOHIVE_UPSTREAM:-}" \
    ONEBORD_PROC_ROOT="${ONEBORD_PROC_ROOT:-/proc}" \
    ONEBORD_DISK_PATH="${ONEBORD_DISK_PATH:-/}"
  procd_set_param respawn 3600 5 5
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance
}

reload_service() {
  stop
  start
}
